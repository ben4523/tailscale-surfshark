# ─── Tailscale (required) ─────────────────────────────────────────────────────
TS_AUTHKEY=tskey-auth-REPLACE-ME
TS_ALLOWED_USERS=*
# TS_HOSTNAME=synology-surfshark-exit

# ─── Surfshark (OpenVPN via gluetun) ──────────────────────────────────────────
# IMPORTANT: these are NOT your Surfshark website email/password — they are the
# OpenVPN service credentials from https://my.surfshark.com/vpn/manual-setup/main
# (look for the "service credentials" or "manual setup" username/password).
OPENVPN_USER=
OPENVPN_PASSWORD=

# Country gluetun picks at boot. Switch via the UI afterwards.
SURFSHARK_COUNTRY=France

# ─── Behavior ─────────────────────────────────────────────────────────────────
KILL_SWITCH=true
FAILOVER=true
LOG_LEVEL=info
