# ─── Tailscale (required) ─────────────────────────────────────────────────────
# Pre-auth key from https://login.tailscale.com/admin/settings/keys
# Recommended: reusable, tag:exit-node, no expiry.
TS_AUTHKEY=tskey-auth-REPLACE-ME

# Comma-separated tailnet identities allowed to access the UI.
TS_ALLOWED_USERS=ben@example.com

# Hostname shown in the Tailscale admin (optional).
# TS_HOSTNAME=synology-surfshark-exit

# ─── Surfshark WireGuard private key (required for actual VPN egress) ────────
# One-time setup:
#   1. Log in at https://my.surfshark.com/vpn/manual-setup/main/wireguard
#   2. Click "I don't have a key pair" → "Generate a new key pair"
#   3. Click any location → "Download" the .conf file
#   4. Open the .conf, copy the value after "PrivateKey = ..."
#   5. Paste below
# This SAME private key works for every Surfshark WG server, so you do this once.
# The container fetches the server list automatically (no Surfshark login needed).
SURFSHARK_PRIVATE_KEY=

# ─── Behavior ─────────────────────────────────────────────────────────────────
# Kill switch: when ON, traffic from exit-node clients is blocked unless wg0 is up.
KILL_SWITCH=true

# Auto-failover: switch to next preferred location when wg0 stays unhealthy.
FAILOVER=true

# Log level: debug | info | warn | error
LOG_LEVEL=info
